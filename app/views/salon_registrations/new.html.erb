<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-6">

    <%# Progress indicator %>
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 rounded-full bg-black text-white flex items-center justify-center text-sm font-bold">1</div>
      <div class="flex-1 h-1 bg-gray-200 mx-2"></div>
      <div class="w-8 h-8 rounded-full bg-gray-200 ...">2</div>

    </div>

    <h1 class="text-2xl font-bold mb-1">Tell us about your salon</h1>
    <p class="text-gray-500 text-sm mb-6">Step 1 of 2</p>

    <%= form_with url: salon_registration_path, class:"" do |form| %>
    
    <%= fields_for :tenant, @tenant do |t|%>
      <div>
            <div class="mb-2">
                <%= t.label :name %>
                <%= t.text_field :name, required: true, autofocus: true, autocomplete: "given-name", class:"block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>

            <div class="">
              <p class="text-sm text-gray-500 mt-1">
                 Your booking link: 
                  <span id="subdomain_preview" class="font-medium text-black">
                        your-salon.rembohub.co.ke
                  </span>
              </p>
              <%= t.label :subdomain %>
              <%= t.text_field :subdomain, placeholder: "salon-name-link", required: true, autocomplete: "family-name", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>

          </div>
            
            <div class="mt-1">
              <%= t.label :location %>
              <%= t.text_field :location, required: true, autocomplete: "email", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>

            <div class=" mt-2">
              <%= t.label :phone_number %>
              <%= t.text_field :phone_number, required: true, autocomplete: "new-password", class: "block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>

            <div class="mt-2">
              <%= t.label :email %>
              <%= t.email_field :email, required: true, autocomplete: "new-password", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>
             <div class="mt-2">
              <%= t.label :operating_hours %>
              <%= t.text_field :operating_hours, required: true, placeholder:"Mon-Sat: 8am-6pm, Sun: Closed", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
            </div>

            
    <% end %>
    
      <div class="mb-2 mt-4">
      <%= form.submit "Next",class:"w-64 md:w-80 rounded-lg py-3 px-8 mt-2 bg-black text-white inline-block font-medium cursor-pointer hover:bg-black-200" %>
      </div>


  <% end %>
  </div>
</div>

<script>
  document.getElementById("tenant_name").addEventListener('input', function(){
    let subdomain = this.value
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .trim()


   document.getElementById('tenant_subdomain').value = subdomain
   document.getElementById('subdomain_preview').textContent = subdomain + '.rembobook.co.ke'


  })


</script>
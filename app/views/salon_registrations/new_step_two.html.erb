

<div class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
  <div class="w-full max-w-md bg-white rounded-xl shadow-lg p-6">

<%# Progress indicator %>
    <div class="flex items-center mb-6">
      <div class="w-8 h-8 rounded-full bg-black text-white flex items-center justify-center text-sm font-bold">1</div>
      <div class="flex-1 h-1 bg-gray-200 mx-2"></div>
      <div class="flex-1 h-1 bg-black mx-2"></div>
      <div class="w-8 h-8 rounded-full bg-black text-white flex items-center justify-center text-sm font-bold">2</div>  
    </div>

     <h1 class="text-2xl font-bold mb-1">create your account</h1>
    <p class="text-gray-500 text-sm mb-6">Step 2 of 2</p>
    <%= form_with url: account_salon_registration_path, method: :post, data: { turbo: false } do |form| %>


      <%= fields_for :user, @user do |u| %>
          <div>
              <div class="mb-2">
                  <%= u.label :first_name %>
                  <%= u.text_field :first_name, required: true, autofocus: true, autocomplete: "given-name", class:"block shadow rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
              </div>

              <div class="">
                  <%= u.label :last_name %>
                  <%= u.text_field :last_name, required: true, autocomplete: "family-name", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
              </div>

              </div>
                  
          <div class="mt-1">
              <%= u.label :email_address %>
              <%= u.email_field :email_address, required: true, autocomplete: "email", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
          </div>

          <div class=" mt-2">
          <%= u.label :password %>
          <%= u.password_field :password, required: true, autocomplete: "new-password", class: "block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
          </div>

          <div class="mt-2">
              <%= u.label :password_confirmation %>
              <%= u.password_field :password_confirmation, required: true, autocomplete: "new-password", class:"block shadow rounded-md  border border-gray-400 outline-none px-3 py-2 mt-2 w-64 md:w-80" %>
          </div>

          
          <% end %>
            <div class="mt-2 py-1"><%= link_to "← Back", new_salon_registration_path, class: "mb-2 py-3  px-4" %></div>

            <%= form.submit "Register Salon", class: "w-64 md:w-80 rounded-lg py-3 px-8 mt-2 bg-black text-white inline-block font-medium cursor-pointer hover:bg-black-200" %>

       <% end %>   
    </div> 

</div>           
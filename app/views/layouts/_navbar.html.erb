<!-- Main Navbar Wrapper Container -->
<div class="w-full bg-white border-b border-gray-100 sticky top-0 z-40">

  <!-- Desktop Navigation Menu (Visible on Desktop, Hidden on Mobile Screens) -->
  <div class="hidden max-w-7xl mx-auto md:flex items-center justify-between px-6 lg:px-8 h-20">

    <!-- Left: Branding Logo Layout -->
    <div class="flex items-center">
      <%= link_to root_path, class: "flex-shrink-0 transition active:scale-95" do %>
      <%= render 'layouts/logo' %>
      <% end %>
    </div>

    <!-- Center: Strategic Product Marketing Hyperlinks -->
    <nav class="flex items-center gap-10 text-sm font-semibold tracking-wide text-gray-600">
      <%= link_to 'Pricing', root_path, class: "hover:text-pink-600 transition-colors duration-200" %>
      <%= link_to 'Features', about_us_path, class: "hover:text-pink-600 transition-colors duration-200" %>
      <%= link_to 'Contact us', contact_us_path, class: "hover:text-pink-600 transition-colors duration-200" %>
    </nav>

    <!-- Right: Intent-Driven Authentication Interfaces -->
    <div class="flex items-center gap-5 text-sm font-semibold">
      <% if authenticated? %>
        <% if current_user&.salon_admin? %>
          <%= link_to "Dashboard", dashboard_url(subdomain: current_user.tenant.subdomain), class: "text-gray-700 hover:text-pink-600 transition-colors duration-200" %>
        <% end %>
        <%= button_to "Logout", session_path, method: :delete, class: "text-gray-500 hover:text-red-600 transition-colors duration-200 cursor-pointer font-semibold" %>
      <% else %>
        <%= link_to "Log in", new_session_path, class: "text-gray-700 hover:text-pink-600 transition-colors duration-200" %>
        <%= link_to 'Register Your Salon', new_salon_registration_path, class: "bg-pink-600 hover:bg-pink-700 text-white px-5 py-3 rounded-xl shadow-md shadow-pink-600/10 hover:shadow-lg transition-all duration-200 block" %>
      <% end %>
    </div>

  </div>

  <!-- Mobile Navigation Header Bar (Visible on Mobile Viewports Only) -->
  <div data-controller="mobile-new" class="py-3 shadow-md md:hidden">
    <div class="flex justify-between mx-4 items-center">
      <%= link_to root_path do %>
       <%= render 'layouts/logo' %>
      <% end %>
      <svg data-action="click->mobile-new#toggle" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
    </div>

    <div class="relative">
      <div data-mobile-new-target="menu2" class="hidden text-center pt-10 mobile-bg transition space-y-6 fixed top-0 left-0 w-full h-full shadow transform -translate-x duration-300 ease-in-out z-50">
        <button data-action="click->mobile-new#toggle">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="hover:bg-red-500 size-6 absolute top-5 right-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>

        <ul class="flex flex-col gap-10 items-center text-gray-600 font-semibold tracking-wide">
          <li class="hover:text-red-300 transition duration-300 ease-in-out transform hover:translate-x-1"><%= link_to 'HOME', root_path %></li>
          <li class="hover:text-red-300 transition duration-300 ease-in-out transform hover:translate-x-1"><%= link_to 'ABOUT US', about_us_path %></li>
          <li class="hover:text-red-300 transition duration-300 ease-in-out transform hover:translate-x-1"><%= link_to 'PRICING', root_path %></li>
          <li class="hover:text-red-300 transition duration-300 ease-in-out transform hover:translate-x-1"><%= link_to 'CONTACT US', contact_us_path %></li>
        </ul>

        <div class="flex flex-col gap-10 flex-1">
          <% if authenticated? %>
            <% if current_user&.salon_admin? %>
              <%= link_to "Dashboard", dashboard_url(subdomain: current_user.tenant.subdomain), class: "text-gray-700 hover:text-pink-600 transition-colors duration-200" %>
            <% end %>
            <%= button_to "Logout", session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-gray-100" %>
          <% else %>
            <%= link_to "Log in", new_session_path, class: "text-gray-700 hover:text-pink-600 transition-colors duration-200" %>
          <% end %>
        </div>

        <% unless authenticated? %>
          <%= link_to 'Register Your Salon', new_salon_registration_path, class: "bg-pink-600 hover:bg-pink-700 text-white px-4 py-3 rounded-xl shadow-md shadow-pink-600/10 hover:shadow-lg transition-all duration-200 block" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
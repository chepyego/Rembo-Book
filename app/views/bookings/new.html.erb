<div class="mb-0 md:mb-6 bg-white flex flex-col lg:flex-row items-center justify-center gap-12 max-w-6xl md:mx-auto px-6 py-10">

  <!-- Mobile-Only Top Image -->
  <div class="block lg:hidden w-full max-w-md overflow-hidden rounded-2xl shadow-xs">
    <%= image_tag 'book.jpg', class: "w-full h-48 object-cover" %>
  </div>

  <!-- Left Side: Header Text + Booking Form Grouped Together -->
  <div class="flex flex-col w-full lg:w-1/2 space-y-6">
    
    <!-- Dynamic Header -->
    <div class="text-center lg:text-left">
      <h1 class="text-2xl font-extrabold text-slate-900 tracking-tight sm:text-3xl">
        Book Your <%= @service.title %>
      </h1>
      <p class="mt-2 text-sm sm:text-base font-medium text-slate-600 text-balance">
        Experience the best in town at <span class="font-semibold text-slate-900"><%= Current.tenant.name %></span>. Ready to look and feel your best?
      </p>
    </div> 

    <!-- Form Container -->
    <div turbo-frame id="booking_form" class="w-full flex justify-center lg:justify-start">
      <%= form_with model: @booking, data: { turbo_frame: "_top" }, class: "w-full max-w-sm" do |form| %>
        
        <div>
          <%= form.label :name, class: "text-sm font-medium text-gray-700" %><br>
          <%= form.text_field :name, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
        </div>

        <div class="mt-4">
          <%= form.label :email, class: "text-sm font-medium text-gray-700" %><br>
          <%= form.text_field :email, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
        </div>

        <div class="mt-4">
          <%= form.label :phone_number, class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_field :phone_number, class: "block shadow-sm rounded-md border border-gray-400 outline-none px-3 py-2 mt-2 w-full" %>
        </div>

        <div class="mt-4">
          <%= form.label :service_id, "Select a service", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.collection_select :service_id, Current.tenant.services, :id, :title, { selected: params[:service_id] }, class: "w-full py-2.5 px-3 border border-gray-400 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500" %>
        </div>

        <div class="mt-4 mb-6">
          <%= form.label :date, "Select Date and time", class: "block text-sm font-medium text-gray-700 mb-1" %><br>
          <%= form.text_field :date, data: { controller: "flatpickr", flatpickr_enable_time: true, flatpickr_date_format: "Y-m-d H:i" }, class: "w-full py-2 px-3 border border-gray-400 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500" %>
        </div>

        <%= form.submit "Book Now", class: "shadow-md transition-all w-full rounded-lg py-3 px-8 bg-pink-600 hover:bg-pink-700 text-white inline-block font-medium cursor-pointer text-center" %>
      <% end %>  
    </div>
  </div>

  <!-- Right Side: Desktop Only Image -->
  <div class="hidden lg:flex w-1/2 justify-center items-center">
    <%= image_tag 'book.jpg', class: "w-full max-h-[550px] object-cover rounded-2xl shadow-md border border-slate-100" %>
  </div>

</div>
<div class="my-12">
  <h1 class="text-center text-2xl font-bold text-gray-900 mb-6 py-6">  my bookings</h1>

  <div class=" grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      <% @bookings.each do |booking| %>
        <div  class=" bg-white rounded-xl shadow-md overflow-hidden max-w-md mx-auto mb-8 p-6 transition-transform hover:scale-[1.02] duration-200"> 

        <p>💅  <%= booking.service.title %></p>
        <p class="mb-2 mt-2"><%= booking.name %></p>
        <p class="mb-2"><%= booking.phone_number %></p>
          <p class="flex items-center text-red-400 ">
            <span class="h-4 w-4 mr-2 ">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" strokeWidth={1.5} stroke="currentColor" className="text-red-400 size-2">
                  <path strokeLinecap="round" strokeLinejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              </span>
              <%= booking.date&.strftime("%d %b %Y • %I:%M %p") %><br>
          
          </p>
          
          </div>
        <% end %>
     </div> 
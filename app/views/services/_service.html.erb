<div class="bg-white rounded-xl shadow-md overflow-hidden max-w-md mx-auto mb-8 p-6 transition-transform hover:scale-[1.02] duration-200" id="<%= dom_id service %>">
  <% if service.image.attached? %>
    <%= image_tag service.image.variant(resize_to_limit: [600, 600]), class: "w-full h-64 object-cover rounded-md mb-4" %>
  <% end %>

  <h2 class="text-xl font-semibold text-gray-800 mb-2 capitalize"><%= service.title %></h2>

  <p class="text-lg text-pink-600 font-semibold mb-2">KES <%= service.price %></p>

  <p class="text-gray-700 mb-4 text-sm">
    <strong class="font-medium block mb-1">Description:</strong>
    <%= service.description.presence || "No description provided." %>
  </p>

  <div class="flex justify-between items-center mt-4 gap-3">
    <%= link_to "View Details", service, class: "px-4 py-2 bg-gray-100 text-gray-800 rounded-md text-sm font-medium hover:bg-gray-200 transition" %>
      
        <%  if current_user&.staff?%>
          <%= link_to 'edit', edit_service_path(service), class:"px-4 py-2  text-white rounded-md hover:bg-blue-700 bg-blue-600 text-sm font-medium shadow transition" %>
          <%= button_to 'delete', service_path(service), method: :delete, alert:"are you sure you want to delete", class:"px-4 py-2 bg-red-500 text-white rounded-md font-medium" %>
          <% else %>
                <%= link_to "Book Now", new_booking_path(service_id: service.id), class: "px-4 py-2 bg-pink-600 text-white rounded-md text-sm font-medium hover:bg-pink-700 shadow transition" %>

        <% end%> 
  
  </div>
   

</div>
